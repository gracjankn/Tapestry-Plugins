{
  "input": [
	  {
		  "match": "/^@?([a-zA-Z0-9_]+)@([a-zA-Z0-9._-]+\\.[a-zA-Z]{2,})$/",
		  "url": "https://$2/c/$1"
	  }
  ],
  "url": [
	{
	  "extract": "^(https?://[^/]+)/(c|accounts)/([^/]+)",
	  "variable": "site, instanceBaseUrl, channelIdentifier"
	}
  ],
  "html": [
	{
	  "element": "meta",
	  "check": "property",
	  "match": "og:platform",
	  "content": "content",
	  "contentMatch": "PeerTube"
	}
  ]
}
